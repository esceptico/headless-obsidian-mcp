HEADLESS_OBSIDIAN_MCP_VAULT_ROOT="$HOME/path/to/vault"
HEADLESS_OBSIDIAN_MCP_AUTH_TOKEN="change-me"
HEADLESS_OBSIDIAN_MCP_HOST=127.0.0.1
HEADLESS_OBSIDIAN_MCP_PORT=8008

